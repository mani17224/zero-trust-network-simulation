# ══════════════════════════════════════════════════════
# Zero Trust Network Simulation — Environment Variables
# Copy to .env:  cp .env.example .env
# ══════════════════════════════════════════════════════

# ── Application ────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── JWT Secret (REQUIRED — change before running) ──────
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE-ME-generate-with-openssl-rand-hex-32

# ── Dev-mode CN override (ONLY when DEBUG=true) ────────
# Lets you test without real TLS certs.
# Example: DEV_CLIENT_CN=gateway.zerotrust.local
DEV_CLIENT_CN=

# ── Vault ──────────────────────────────────────────────
VAULT_DEV_TOKEN=root-token-dev
VAULT_ADDR=http://vault:8200

# ── Service URLs (HTTP inside Docker — no certs needed) ─
SERVICE_A_URL=http://service-a:8001
SERVICE_B_URL=http://service-b:8002
SERVICE_C_URL=http://service-c:8003

# ── OPA ────────────────────────────────────────────────
OPA_URL=http://opa:8181
OPA_CACHE_TTL_SECONDS=10

# ── CORS (all origins for dev — restrict in prod) ──────
CORS_ORIGINS=*

# ── Rate Limiting ──────────────────────────────────────
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_LOGIN=10/minute

# ── Grafana ────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=zerotrust

# ── Frontend ───────────────────────────────────────────
# URL the BROWSER uses to reach the gateway
VITE_GATEWAY_URL=http://localhost:8000
# URL the BROWSER uses to reach OPA (for Policy Tester)
VITE_OPA_URL=http://localhost:8181

# ── WireGuard (for real multi-VM setup) ───────────────
GATEWAY_HOST=10.0.0.1
SERVICE_NODE_HOST=10.0.0.2
CLIENT_NODE_HOST=10.0.0.3
